<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F0C">

    <!-- Ambient blob top-left -->
    <View
        android:id="@+id/blobTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/blob_circle"
        android:alpha="0.07"
        android:translationX="-80dp"
        android:translationY="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Ambient blob bottom-right -->
    <View
        android:id="@+id/blobBot"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/blob_circle"
        android:alpha="0.05"
        android:translationX="60dp"
        android:translationY="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scroll container -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="56dp"
            android:paddingBottom="40dp">

            <!-- Settings button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:layout_marginBottom="0dp">
                <ImageView
                    android:id="@+id/btnSettings"
                    android:layout_width="43dp"
                    android:layout_height="43dp"
                    android:background="@drawable/bg_icon_btn"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="invisible"
                    app:tint="#10B981" />
            </LinearLayout>

            <!-- HERO SECTION -->
            <LinearLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="invisible">

                <!-- Eyebrow label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BIM AI LEARNING TOOL"
                        android:textColor="#10B981"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.25"
                        android:alpha="0.80"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="30dp"
                        android:layout_height="1dp"
                        android:background="#10B981"
                        android:alpha="0.40"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SmartBIM - \nWhere Hands\nSpeak"
                    android:textColor="#E8F5EC"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.15"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="10dp" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learn &amp; communicate using Bahasa\nIsyarat Malaysia with ease."
                    android:textColor="#6B9B7A"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.65" />

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:id="@+id/dividerLine"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/gradient_divider"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="22dp" />

            <!-- Card 1: Sign to Text -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnTranslator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="invisible"
                app:cardBackgroundColor="#141F17"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A3DDC84"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_icon_card_green">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_translate_sign"
                            app:tint="#10B981" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign to Text"
                            android:textColor="#E8F5EC"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detect &amp; translate BIM gestures"
                            android:textColor="#6B9B7A"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_arrow_btn">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Go"
                            app:tint="#10B981" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Speech to Sign -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnSpeechToSign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="invisible"
                app:cardBackgroundColor="#141F17"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A3DDC84"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_icon_card_teal">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_translate_speech"
                            app:tint="#10B981" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speech to Sign"
                            android:textColor="#E8F5EC"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speak or type, see BIM signs"
                            android:textColor="#6B9B7A"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_arrow_btn">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Go"
                            app:tint="#10B981" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Practice & Game -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="invisible"
                app:cardBackgroundColor="#141F17"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A3DDC84"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_icon_card_lime">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:paddingStart="4dp"
                            android:src="@drawable/ic_practice_game"
                            app:tint="#10B981" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Practice &amp; Game"
                            android:textColor="#E8F5EC"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="3dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quiz mode and game mode"
                            android:textColor="#6B9B7A"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_arrow_btn">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chevron_right"
                            android:contentDescription="Go"
                            app:tint="#10B981" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Train Data - COMMENTED OUT
            <androidx.cardview.widget.CardView
                android:id="@+id/btnTrain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
